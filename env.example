# ============================================================================
# BAPS Backend Server - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# Do NOT commit the .env file to version control
# ============================================================================


# ============================================================================
# APP CONFIGURATION
# ============================================================================
APP_NAME=BAPS Backend Server
APP_VERSION=1.0.0
APP_DESCRIPTION=Building Asset Portal System Backend
APP_ENVIRONMENT=development
APP_DEBUG=True
APP_LOG_LEVEL=INFO
APP_DOCS_ENABLED=True
APP_CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]


# ============================================================================
# POSTGRESQL DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=baps_parivar_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Admin1234
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
POSTGRES_ECHO=False


# ============================================================================
# REDIS CACHE CONFIGURATION
# ============================================================================
# Redis server for caching and session management
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=
REDIS_SSL=False
REDIS_MAX_CONNECTIONS=50
REDIS_DECODE_RESPONSES=True


# ============================================================================
# RABBITMQ MESSAGE QUEUE CONFIGURATION
# ============================================================================
# RabbitMQ for async task processing and message queuing
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_POOL_SIZE=10
RABBITMQ_HEARTBEAT=60


# ============================================================================
# SMTP EMAIL CONFIGURATION
# ============================================================================
# SMTP settings for email notifications and transactional emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@baps.com
SMTP_FROM_NAME=BAPS System
SMTP_USE_TLS=True
SMTP_USE_SSL=False
SMTP_TIMEOUT=10


# ============================================================================
# JWT SECURITY CONFIGURATION
# ============================================================================
# Security settings for JWT tokens and password validation
SECURITY_SECRET_KEY=your-secret-key-change-in-production
SECURITY_ALGORITHM=HS256
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=30
SECURITY_REFRESH_TOKEN_EXPIRE_DAYS=7
SECURITY_PASSWORD_MIN_LENGTH=8
SECURITY_PASSWORD_REQUIRE_UPPERCASE=True
SECURITY_PASSWORD_REQUIRE_NUMBERS=True
SECURITY_PASSWORD_REQUIRE_SPECIAL=True


# ============================================================================
# SERVER CONFIGURATION (Legacy)
# ============================================================================
SERVER_HOST=127.0.0.1
SERVER_PORT=9000

